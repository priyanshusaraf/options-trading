# ── API Keys ────────────────────────────────────────────────────────────────
ALPHA_VANTAGE_KEY=your_alpha_vantage_key
FINNHUB_KEY=your_finnhub_key
FMP_KEY=your_financial_modeling_prep_key       # https://financialmodelingprep.com
FRED_KEY=your_fred_key                          # https://fred.stlouisfed.org/docs/api

# ── Zerodha Kite ─────────────────────────────────────────────────────────────
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=                              # Set after OAuth flow

# ── App Config ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=3600                          # 1 hour default cache
BENCHMARK_SYMBOL=^NSEI                          # Nifty 50 as benchmark

# ── Paths (relative to repo root) ────────────────────────────────────────────
DATA_DIR=data
PARQUET_DIR=data/parquet
SQLITE_PATH=data/sqlite/market.db
REPORTS_DIR=data/reports
CACHE_DIR=data/cache

# ── Portfolio ─────────────────────────────────────────────────────────────────
DEFAULT_CURRENCY=INR
RISK_FREE_RATE=0.065                            # 6.5% (India 10yr Gsec approximate)
