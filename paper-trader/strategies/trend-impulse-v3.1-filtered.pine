//@version=5
// =====================================================================
// Trend Impulse V3.1 — exact V3 math + evidence-driven entry filters
// =====================================================================
// WHAT THIS IS
//   The original EMA50 + displacement (z-score) strategy, byte-for-byte the
//   same math as backend/app/strategy/signals.py (the Python source of truth),
//   plus THREE optional filters that came out of the 2026-07 sector autopsy of
//   21,445 backtested trades (run 10, Sep'25–Jun'26 window):
//
//     F1  OPENING BLACKOUT  (default ON) — entries in 09:15–10:15 lost money
//         in EVERY sector (banking −13 bps/trade, pharma −25, mfg −11,
//         index −29). All of banking's profit came 12:00→close.
//     F2  CLOSING BLACKOUT  (default OFF) — for overnight-gap-driven sectors
//         (pharma −41 bps in the 14:30–close bucket). Turn ON for pharma-like
//         names, leave OFF for flow sectors (mfg made +60 bps there).
//     F3  SIDE TOGGLES      (default both ON) — pharma shorts averaged
//         −27.7 bps/trade vs longs −4.5; most losing-tail names lose
//         disproportionately on shorts. Long-only is one click.
//
// DUAL USE
//   * 15m/30m chart  -> the live intraday strategy with filters (S5).
//   * DAILY chart    -> "daily_impulse_v1" (S1): identical params were
//     profitable on multi-year daily bars for pharma/IT/telecom/power
//     (sector-median PF 1.20 for pharma vs 0.5–0.8 intraday). Session
//     blackouts are automatically inert on daily bars (time() returns na).
//
// PINE -> PYTHON PARITY (keep true when porting back to the registry)
//   * z = (close − EMA50) / stdev(CLOSE, 50)   — RAW-close stdev, population
//     (Pine ta.stdev default biased=true == pandas .std(ddof=0)). This is V3;
//     V4 uses stdev of the RESIDUAL — do not mix them up.
//   * longEntry  = slope>0 and z[1]<entryZ and z>entryZ and z>z[1]
//   * shortEntry = slope<0 and z[1]>−entryZ and z<−entryZ and |z|>|z[1]|
//   * longExit   = z<0 or slope<0        (displacement lost / trend flip)
//   * Exits are PURE SIGNAL — no stop/target here, because the live engine
//     owns the risk layer (premium SL/TP + trail) and the platform backtests
//     you are verifying against are signal-exit-only. Compare apples to apples.
//
// EXECUTION MODEL (house convention, same as expanding-z-impulse-v4.pine)
//   Signals evaluate on confirmed bars only; orders fill on the NEXT bar open
//   (process_orders_on_close=false). No same-bar fills, no lookahead.
//
// SIZING: fixed contracts (default 1) — lockstep with the engine's
//   fixed-1-lot additive model. Use TV Properties for commission/slippage
//   (suggest 0.03% per order + 1–2 ticks to approximate the charge stack).
// =====================================================================

strategy(
     "Trend Impulse V3.1 (filtered)",
     overlay=true,
     initial_capital=100000,
     pyramiding=0,
     process_orders_on_close=false,
     calc_on_order_fills=false,
     calc_on_every_tick=false)

// =====================================================
// Inputs — V3 core (identical defaults to the Python engine)
// =====================================================
emaLength     = input.int(50,  "EMA Length",            minval=1, group="V3 Core")
zLength       = input.int(50,  "Z-Score Length",        minval=5, group="V3 Core")
entryZ        = input.float(1.0, "Entry Z Threshold",   minval=0.1, step=0.05, group="V3 Core")
slopeLookback = input.int(5,   "EMA Slope Lookback",    minval=1, group="V3 Core")

// =====================================================
// Inputs — evidence filters (the ".1" in V3.1)
// =====================================================
enableLongs  = input.bool(true, "Enable Long Entries",  group="Side Filters (F3)")
enableShorts = input.bool(true, "Enable Short Entries", group="Side Filters (F3)")

blockOpen    = input.bool(true,  "Block Entries: Opening Window", group="Session Filters (F1/F2)",
     tooltip="Entries in the first hour lost money in every sector of the 2026 autopsy. Exits are NEVER blocked.")
openWindow   = input.session("0915-1015", "Opening Blackout (exchange time)", group="Session Filters (F1/F2)")
blockClose   = input.bool(false, "Block Entries: Closing Window", group="Session Filters (F1/F2)",
     tooltip="Turn ON for overnight-gap sectors (pharma: −41 bps/trade on 14:30–close entries). Leave OFF for flow sectors.")
closeWindow  = input.session("1430-1530", "Closing Blackout (exchange time)", group="Session Filters (F1/F2)")

// Fixed contracts — lockstep with the engine's 1-lot additive model.
fixedQty = input.float(1.0, "Contracts / Lots", minval=0.01, step=0.01, group="Sizing")

// =====================================================
// V3 core math (source of truth: app/strategy/signals.py)
// =====================================================
ema = ta.ema(close, emaLength)
sd  = ta.stdev(close, zLength)               // population stdev of RAW close (V3)
z   = sd > 0 ? (close - ema) / sd : 0.0
slope = ema - ema[slopeLookback]

bull = slope > 0
bear = slope < 0

longEntryRaw  = bull and z[1] <  entryZ and z >  entryZ and z > z[1]
shortEntryRaw = bear and z[1] > -entryZ and z < -entryZ and math.abs(z) > math.abs(z[1])

longExitSig  = z < 0 or bear                 // displacement lost / trend flip
shortExitSig = z > 0 or bull

// =====================================================
// Filters — entries only; exits always live
// =====================================================
// Session strings return na on non-intraday charts, so both blackouts are
// automatically inert on a DAILY chart (the S1 use-case).
inSess(sess) =>
     not na(time(timeframe.period, sess + ":1234567"))

entryBlocked = (blockOpen and inSess(openWindow)) or (blockClose and inSess(closeWindow))

longSignal =
     barstate.isconfirmed and
     enableLongs and
     not entryBlocked and
     strategy.position_size <= 0 and
     longEntryRaw

shortSignal =
     barstate.isconfirmed and
     enableShorts and
     not entryBlocked and
     strategy.position_size >= 0 and
     shortEntryRaw

// =====================================================
// Entries / exits (fill next bar open)
// =====================================================
if longSignal
    strategy.close("Short", comment="Close Short For Long Signal")
    strategy.entry("Long", strategy.long, qty=fixedQty, comment="V3 Long")

if shortSignal
    strategy.close("Long", comment="Close Long For Short Signal")
    strategy.entry("Short", strategy.short, qty=fixedQty, comment="V3 Short")

if barstate.isconfirmed and strategy.position_size > 0 and longExitSig
    strategy.close("Long", comment="Displacement Lost")

if barstate.isconfirmed and strategy.position_size < 0 and shortExitSig
    strategy.close("Short", comment="Displacement Lost")

// =====================================================
// Visuals
// =====================================================
plot(ema, title="EMA", color=color.orange, linewidth=2)

plotshape(longSignal,  title="Long Signal",  location=location.belowbar, style=shape.triangleup,   size=size.tiny, color=color.green)
plotshape(shortSignal, title="Short Signal", location=location.abovebar, style=shape.triangledown, size=size.tiny, color=color.red)

bgcolor(entryBlocked and timeframe.isintraday ? color.new(color.gray, 92) : na, title="Entry Blackout Shading")

plot(z,     title="Z-Score",   color=color.blue, display=display.none)
plot(slope, title="EMA Slope", color=color.gray, display=display.none)
