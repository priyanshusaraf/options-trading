//@version=5
// =====================================================================
// Regime Router — which strategy family does THIS instrument deserve?
// =====================================================================
// THE POINT (2026-07 sector autopsy conclusion)
//   The platform's edge is not any single strategy — it is MATCHING each
//   instrument to the strategy family whose statistical habitat it currently
//   exhibits. The autopsy showed the same z-score math earns +154% (SILVERM),
//   +82% (BSE) and −51% (LUPIN) in the same window: the instrument's
//   price-formation regime decides everything. This indicator measures that
//   regime with three dead-simple statistics (all pure arithmetic):
//
//   1. KAUFMAN EFFICIENCY RATIO (trendiness)
//        ER = |close − close[n]| / Σ|Δclose| over n bars      ∈ [0, 1]
//        High ⇒ moves travel somewhere (impulse follow-through exists).
//   2. GAP SHARE (how much of the traversal happens OVERNIGHT)
//        gapShare = Σ|open − close[1]| / Σ(|open − close[1]| + high − low)
//        High ⇒ information lands outside market hours (pharma: US FDA /
//        tariff news) ⇒ intraday displacement-chasing is structurally late.
//   3. DRIFT T-STAT (persistent directional bias)
//        t = mean(logret) / (stdev(logret) / √n)
//        |t| high ⇒ a real drift worth buying pullbacks into.
//
//   ROUTING TABLE (evidence-calibrated STARTING POINTS — validate against the
//   6,718-cell run-11 sweep already sitting in backtest_results before
//   trusting them; that regression is the next platform task):
//     gapShare > 0.35 and ER < 0.25          → EVENT-GAP  : gap_drift / pair_z; NO intraday impulse
//     ER ≥ 0.25 and gapShare ≤ 0.35          → IMPULSE    : trend_impulse_v3 / expanding_z_v4
//     ER < 0.25 and |t| ≥ 2.0                → DRIFT      : pullback_ema
//     otherwise                              → NO EDGE    : stand aside / pair_z only
//
// CHART: apply to a DAILY chart (gap share is meaningless bar-to-bar
//   intraday; the table warns if you forget). Read it weekly per instrument —
//   the platform port recomputes it in the runner and re-routes per-instrument
//   strategy assignments automatically.
// =====================================================================

indicator("Regime Router", overlay=false)

// =====================================================
// Inputs
// =====================================================
erLen    = input.int(100, "Efficiency Ratio Lookback (bars)", minval=20,  group="Stats")
gapLen   = input.int(60,  "Gap Share Lookback (bars)",        minval=20,  group="Stats")
driftLen = input.int(60,  "Drift T-Stat Lookback (bars)",     minval=20,  group="Stats")

erTrend  = input.float(0.25, "ER Trend Threshold",      minval=0.05, step=0.01, group="Routing Thresholds")
gapHigh  = input.float(0.35, "Gap-Share High Threshold", minval=0.05, step=0.01, group="Routing Thresholds")
tStrong  = input.float(2.0,  "Drift |T| Threshold",      minval=0.5,  step=0.1,  group="Routing Thresholds")

// =====================================================
// The three statistics
// =====================================================
// 1. Kaufman Efficiency Ratio
netMove   = math.abs(close - close[erLen])
totalPath = math.sum(math.abs(ta.change(close)), erLen)
er = totalPath > 0 ? netMove / totalPath : na

// 2. Gap share of total traversal (overnight |gap| vs gap + intrabar range)
gapAbs   = math.abs(open - close[1])
traversal = gapAbs + (high - low)
gapShare = math.sum(traversal, gapLen) > 0 ?
     math.sum(gapAbs, gapLen) / math.sum(traversal, gapLen) : na

// 3. Drift t-stat of log returns
logret = math.log(close / close[1])
retMean = ta.sma(logret, driftLen)
retSd   = ta.stdev(logret, driftLen)
tStat = retSd > 0 ? retMean / (retSd / math.sqrt(driftLen)) : na

// =====================================================
// Routing verdict
// =====================================================
isEventGap = not na(gapShare) and not na(er) and gapShare > gapHigh and er < erTrend
isImpulse  = not na(er) and not na(gapShare) and er >= erTrend and gapShare <= gapHigh
isDrift    = not na(er) and not na(tStat) and er < erTrend and math.abs(tStat) >= tStrong and not isEventGap

verdict = isEventGap ? "EVENT-GAP" : isImpulse ? "IMPULSE" : isDrift ? "DRIFT" : "NO EDGE"
family  = isEventGap ? "gap_drift_v1 / pair_z_v1 — avoid intraday impulse" :
          isImpulse  ? "trend_impulse_v3 / expanding_z_v4" :
          isDrift    ? "pullback_ema_v1" :
                       "stand aside / pair_z_v1 only"
vColor  = isEventGap ? color.orange : isImpulse ? color.green : isDrift ? color.teal : color.gray

// =====================================================
// Pane plots (history of the regime)
// =====================================================
plot(er,       title="Efficiency Ratio", color=color.green,  linewidth=2)
plot(gapShare, title="Gap Share",        color=color.orange, linewidth=2)
plot(tStat / 10.0, title="Drift T-Stat (÷10 to fit)", color=color.blue, linewidth=1)
hline(0.25, "ER Trend Threshold (default)",  color=color.new(color.green, 60),  linestyle=hline.style_dashed)
hline(0.35, "Gap-Share Threshold (default)", color=color.new(color.orange, 60), linestyle=hline.style_dashed)
bgcolor(color.new(vColor, 88), title="Regime Shading")

// =====================================================
// Table
// =====================================================
var table t = table.new(position.top_right, 2, 6, border_width=1)
if barstate.islast
    table.cell(t, 0, 0, "REGIME ROUTER", text_color=color.white, bgcolor=color.new(color.black, 20))
    table.cell(t, 1, 0, verdict,         text_color=color.white, bgcolor=vColor)

    table.cell(t, 0, 1, "Route to",      text_color=color.white, bgcolor=color.new(color.black, 40))
    table.cell(t, 1, 1, family,          text_color=color.white, bgcolor=color.new(vColor, 40))

    table.cell(t, 0, 2, "Efficiency Ratio (" + str.tostring(erLen) + ")", text_color=color.white, bgcolor=color.new(color.black, 40))
    table.cell(t, 1, 2, str.tostring(er, "#.###") + "  (trend ≥ " + str.tostring(erTrend, "#.##") + ")",
         text_color=color.white, bgcolor=color.new(er >= erTrend ? color.green : color.gray, 40))

    table.cell(t, 0, 3, "Gap Share (" + str.tostring(gapLen) + ")", text_color=color.white, bgcolor=color.new(color.black, 40))
    table.cell(t, 1, 3, str.tostring(gapShare, "#.###") + "  (event ≥ " + str.tostring(gapHigh, "#.##") + ")",
         text_color=color.white, bgcolor=color.new(gapShare > gapHigh ? color.orange : color.gray, 40))

    table.cell(t, 0, 4, "Drift T-Stat (" + str.tostring(driftLen) + ")", text_color=color.white, bgcolor=color.new(color.black, 40))
    table.cell(t, 1, 4, str.tostring(tStat, "#.##") + "  (strong ≥ ±" + str.tostring(tStrong, "#.#") + ")",
         text_color=color.white, bgcolor=color.new(math.abs(nz(tStat)) >= tStrong ? color.teal : color.gray, 40))

    table.cell(t, 0, 5, "Timeframe", text_color=color.white, bgcolor=color.new(color.black, 40))
    table.cell(t, 1, 5, timeframe.isintraday ? "⚠ USE A DAILY CHART (gap share invalid intraday)" : "Daily ✓",
         text_color=color.white, bgcolor=color.new(timeframe.isintraday ? color.red : color.green, 40))
