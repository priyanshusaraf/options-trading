# ─── Provider ────────────────────────────────────────────────────────────────
# "mock"  -> fully self-contained synthetic market. No Kite needed. (default)
# "kite"  -> live Zerodha Kite Connect. Requires the credentials below.
PT_PROVIDER=mock

# Only used when PT_PROVIDER=kite. The mock provider ignores these.
KITE_API_KEY=
KITE_API_SECRET=

# ─── Telegram alerts (optional) ──────────────────────────────────────────────
# Leave blank to disable notifications. To enable: message @BotFather to create a
# bot and copy its token; message your new bot once, then open
#   https://api.telegram.org/bot<token>/getUpdates
# and copy the "chat":{"id":...} value.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Capital & risk ──────────────────────────────────────────────────────────
PT_INITIAL_CAPITAL=50000
PT_STOP_LOSS_PCT=0.30      # close if option premium falls 30% below entry
PT_TARGET_PCT=0.60         # close if option premium rises 60% above entry

# ─── Option picker ───────────────────────────────────────────────────────────
PT_TARGET_DELTA=0.50       # pick the contract whose |delta| is closest to this
PT_DELTA_BAND=0.15         # acceptable band around target (0.35 .. 0.65)
PT_MIN_OI=500              # liquidity floor: minimum open interest
PT_MAX_SPREAD_PCT=0.03     # liquidity floor: max bid-ask spread as % of premium

# ─── Strategy ────────────────────────────────────────────────────────────────
PT_INTERVAL=15minute       # 15minute or 30minute ONLY (strategy is tuned for these)
PT_EMA_LENGTH=50
PT_Z_LENGTH=50
PT_ENTRY_Z=1.0
PT_SLOPE_LOOKBACK=5

# ─── Mock demo clock ─────────────────────────────────────────────────────────
# Real seconds between simulated candle advances. Lower = faster demo.
PT_MOCK_TICK_SECONDS=3
PT_MOCK_SEED=7
PT_MOCK_HISTORY_DAYS=90

# ─── Misc ────────────────────────────────────────────────────────────────────
PT_RISK_FREE_RATE=0.065
PT_DB_PATH=paper_trader.db

# ─── API auth + CORS ─────────────────────────────────────────────────────────
# Blank = auth disabled (default; fine for localhost-only dev). Set this to require
# a bearer token on every REST/WS call except /api/health and the Kite OAuth
# redirect endpoints (/api/login, /api/session). Pair with VITE_PT_TOKEN in the
# frontend's .env so the app can still talk to the API.
# PT_API_TOKEN=
# Comma-separated browser origins allowed to call the API with credentials.
# PT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
